# ─── Trade Executor Configuration (Windows Server) ───

# API auth secret (same value must be set in scanner's EXECUTOR_API_SECRET)
EXECUTOR_API_SECRET=your-random-secret-here

# Risk limits
MAX_OPEN_POSITIONS=5

# Logs
LOG_FILE=C:/trade-executor/trades.log
TRADE_LOG_JSON=C:/trade-executor/trades.jsonl
