# ─── Trade Executor Configuration ───

# API auth secret (same value must be set in scanner's EXECUTOR_API_SECRET)
EXECUTOR_API_SECRET=your-random-secret-here

# Telegram notifications (reuse from scanner or separate)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_CHAT_ID=-1001234567890

# MT5 / Wine paths
WINEPREFIX=/opt/trade-executor/wine
WINE_PYTHON=python.exe
DISPLAY=:99

# Risk limits
MAX_OPEN_POSITIONS=5

# Logs
LOG_FILE=/opt/trade-executor/trades.log
TRADE_LOG_JSON=/opt/trade-executor/trades.jsonl
