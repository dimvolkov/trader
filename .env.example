# Telegram (обязательно)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_CHAT_ID=-1001234567890

# Источник данных: twelvedata, tradermade, polygon, finnhub, fcsapi, alphavantage, oanda
DATA_SOURCE=twelvedata

# API ключи (укажите для выбранного источника)
API_KEY_TWELVEDATA=your_twelvedata_key
API_KEY_TRADERMADE=
API_KEY_POLYGON=
API_KEY_FINNHUB=
API_KEY_FCSAPI=
API_KEY_ALPHAVANTAGE=
API_KEY_OANDA=

# Валютные пары (через запятую)
WATCHLIST=EUR/USD,USD/JPY,GBP/USD,USD/CHF,AUD/USD,USD/CAD,NZD/USD

# Расписание (московское время UTC+3)
SCHEDULE_FROM=8
SCHEDULE_TO=20
SCAN_INTERVAL_HOURS=1

# Управление рисками
DEPOSIT=100000
RISK_PCT=0.01

# Домен для ссылок на график
DOMAIN=trader.kachestvobiz-ai.ru

# Авто-трейдинг (Trade Executor)
AUTO_TRADE=false
EXECUTOR_URL=http://your-executor-server:8500
EXECUTOR_API_SECRET=your-random-secret-here

# Ежедневный отчёт в Telegram (итоги торгового дня)
# DAILY_REPORT_ENABLED=false  — выключить (по умолчанию включён)
# DAILY_REPORT_MSK_HOUR — час по МСК, когда отправлять отчёт (по умолчанию 22)
DAILY_REPORT_ENABLED=true
DAILY_REPORT_MSK_HOUR=22

# ─── Auth (вход в веб-интерфейс) ─────────────────────────────────────────────
# Стабильный секрет для подписи сессионных cookie. Сгенерируйте: openssl rand -base64 32
AUTH_SECRET=please-change-me-to-a-long-random-string-please-change
APP_NAME=Trader
APP_BASE_URL=https://trader.kachestvobiz-ai.ru

# Тестовая учётка: создаётся автоматически, если в /data/auth-users.json её ещё нет.
# После первого запуска можно сменить пароль через «Забыли пароль?» либо
# отредактировать значения и очистить файл с пользователями.
INITIAL_USER_EMAIL=test@trader.local
INITIAL_USER_PASSWORD=trader12345
INITIAL_USER_NAME=Test user

# SMTP. Если хотя бы один из HOST/USER/PASSWORD не задан — письма уходят в stdout (dev-режим).
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=Trader <noreply@trader.kachestvobiz-ai.ru>
